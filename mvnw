# ----------------------------------------------------------------------------
# Maven Wrapper startup script for Unix/macOS
# ----------------------------------------------------------------------------

set -e

DIRNAME=`dirname "$0"`
WRAPPER_JAR="$DIRNAME/.mvn/wrapper/maven-wrapper.jar"

# Download Wrapper Jar if not present
if [ ! -f "$WRAPPER_JAR" ]; then
    echo "Downloading Maven Wrapper Jar..."
    mkdir -p "$DIRNAME/.mvn/wrapper"
    curl -sL https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar -o "$WRAPPER_JAR"
fi

# Run Maven
exec java -classpath "$WRAPPER_JAR" "-Dmaven.multiModuleProjectDirectory=$DIRNAME" org.apache.maven.wrapper.MavenWrapperMain "$@"
